      TokenData memory tokenData;
      tokenData.erc20Data = new ERC20Data[](1);
      tokenData.erc20Data[0] = ERC20Data({token: tokenIn, amount: swapAmount, permitData: ''});
      actionData = _getActionData(tokenData, '', true);
