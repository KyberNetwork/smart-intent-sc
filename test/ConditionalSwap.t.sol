    _executeSwap(mode, intentData, actionData);
    actionData.nonce += 1;
    _expectExecuteRevert(mode, intentData, actionData, KSConditionalSwapHook.InvalidSwap.selector);

    assertEq(conditionalSwapHook.getSwapExecutionCount(hash, 0, 0), 1);
